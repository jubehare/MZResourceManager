<Window x:Class="MZResourceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MZResourceManager.Views"
        Title="MZ Resource Manager"
        Height="700"
        Width="1100"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppColorMain1Brush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource AppColorBorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu Padding="2,0">
                <MenuItem Header="_File"
                          Padding="8,5">
                    <MenuItem Header="Open Game Folder…"
                              Command="{Binding OpenProjectCommand}"/>
                    <MenuItem Header="Reload"
                              Command="{Binding ReloadProjectCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit"
                              Command="{Binding ExitCommand}"/>
                </MenuItem>
                <MenuItem Header="_Tools"
                          Padding="8,5">
                    <MenuItem Header="Unused Resource Scan"
                              Command="{Binding OpenUnusedScanCommand}"/>
                    <MenuItem Header="Script Book Export"
                              Command="{Binding OpenScriptBookCommand}"/>
                </MenuItem>
                <MenuItem Header="_Help"
                          Padding="8,5">
                    <MenuItem Header="View on GitHub"
                              Command="{Binding OpenGitHubCommand}"/>
                    <Separator/>
                    <MenuItem Header="About"
                              Command="{Binding NavigateHomeCommand}"/>
                </MenuItem>
            </Menu>
        </Border>

        <Grid Grid.Row="1">
            <!-- Welcome -->
            <views:WelcomeView Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}"/>

            <!-- Loading -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading…"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppColorSide2Brush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{Binding LoadStatus}"
                           FontSize="12"
                           Foreground="{StaticResource AppColorSide1Brush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Main -->
            <views:MainView Visibility="{Binding ProjectLoaded, Converter={StaticResource BoolToVis}}"/>

            <Grid Visibility="{Binding HasOverlay, Converter={StaticResource BoolToVis}}"
                  Panel.ZIndex="20">
                <Border Background="#55000000"/>

                <Border Background="White"
                        Margin="48,32"
                        CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28"
                                ShadowDepth="4"
                                          Opacity="0.22"
                                Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header bar -->
                        <Border Grid.Row="0"
                                Background="White"
                                Padding="24,0,10,0"
                                CornerRadius="10,10,0,0"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Height="48">
                            <Grid>
                                <TextBlock Text="{Binding OverlayTitle}"
                                           FontSize="14"
                                        FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           VerticalAlignment="Center"/>

                                <!-- X close button -->
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding CloseOverlayCommand}"
                                        Width="32"
                                        Height="32"
                                        Cursor="Hand"
                                        ToolTip="Close"
                                        Background="Transparent"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="Transparent"
                                                    CornerRadius="6"
                                                    Width="32"
                                                    Height="32">
                                                <TextBlock Text="&#xE8BB;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11"
                                                           Foreground="#555555"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                        Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#F0F0F0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                        Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#E0E0E0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <ContentPresenter Grid.Row="1"
                                          Content="{Binding OverlayContent}"
                                          ClipToBounds="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
