<Window x:Class="MZResourceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MZ Resource Manager"
        Height="700"
        Width="1100"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppColorMain1Brush}">

    <Window.Resources>
        <ControlTemplate x:Key="CtaBtn"
                         TargetType="Button">
            <Border x:Name="Bd"
                    Background="{StaticResource AppColorMain2Brush}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter TargetName="Bd"
                            Property="Background"
                            Value="{StaticResource AppColorSide1Brush}"/>
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter TargetName="Bd"
                            Property="Background"
                            Value="{StaticResource AppColorSide2Brush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="900">

            <TextBlock Text="MZ Resource Manager"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource AppColorSide2Brush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button Content="Open Game Folder…"
                    Command="{Binding OpenProjectCommand}"
                    Template="{StaticResource CtaBtn}"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Padding="40,13"
                    Cursor="Hand"
                    HorizontalAlignment="Center">
                <Button.Effect>
                    <DropShadowEffect Color="{StaticResource AppColorSide2}"
                                      Opacity="0.35"
                                      BlurRadius="14"
                                      ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Window>
