<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AppColorMain1">#FFFFFF</Color>
    <Color x:Key="AppColorMain2">#666666</Color>
    <Color x:Key="AppColorSide1">#444444</Color>
    <Color x:Key="AppColorSide2">#1A1A1A</Color>
    <Color x:Key="AppColorSideLight">#F3F3F3</Color>
    <Color x:Key="AppColorSideLightHover">#E8E8E8</Color>

    <SolidColorBrush x:Key="AppColorMain1Brush"
                     Color="{StaticResource AppColorMain1}"/>
    <SolidColorBrush x:Key="AppColorMain2Brush"
                     Color="{StaticResource AppColorMain2}"/>
    <SolidColorBrush x:Key="AppColorSide1Brush"
                     Color="{StaticResource AppColorSide1}"/>
    <SolidColorBrush x:Key="AppColorSide2Brush"
                     Color="{StaticResource AppColorSide2}"/>
    <SolidColorBrush x:Key="AppColorSideLightBrush"
                     Color="{StaticResource AppColorSideLight}"/>
    <SolidColorBrush x:Key="AppColorSideLightHoverBrush"
                     Color="{StaticResource AppColorSideLightHover}"/>

    <!-- Text -->
    <Color x:Key="AppColorTextMuted">#767676</Color>
    <Color x:Key="AppColorTextBody">#3C3C3C</Color>
    <Color x:Key="AppColorTextLabel">#595959</Color>

    <SolidColorBrush x:Key="AppColorTextMutedBrush"
                     Color="{StaticResource AppColorTextMuted}"/>
    <SolidColorBrush x:Key="AppColorTextBodyBrush"
                     Color="{StaticResource AppColorTextBody}"/>
    <SolidColorBrush x:Key="AppColorTextLabelBrush"
                     Color="{StaticResource AppColorTextLabel}"/>

    <!-- Border -->
    <Color x:Key="AppColorBorder">#D1D1D1</Color>
    <SolidColorBrush x:Key="AppColorBorderBrush"
                     Color="{StaticResource AppColorBorder}"/>

</ResourceDictionary>
