<UserControl x:Class="MZResourceManager.Views.MapListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#D1D1D1"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        Padding="14,12"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Maps"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AppColorSide2Brush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FilteredMaps.Count, StringFormat=' ({0})'}"
                                   FontSize="11"
                                   Foreground="{StaticResource AppColorMain2Brush}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        Padding="8,8"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding MapFilterText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             FontSize="12"
                             BorderBrush="#D1D1D1"
                             BorderThickness="1"/>
                </Border>

                <!-- Map list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredMaps}"
                         SelectedItem="{Binding SelectedMap}"
                         Background="White"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id, StringFormat=D3}"
                                           FontSize="10"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="#767676"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Export -->
            <Border Grid.Row="0"
                    Background="#F3F3F3"
                    Padding="16,10"
                    BorderBrush="#D1D1D1"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectedMap.Name, FallbackValue='Select a map'}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppColorSide2Brush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Export PNG"
                            Command="{Binding ExportMapCommand}"
                            Template="{StaticResource CtaBtn}"
                            Foreground="White"
                            FontSize="12"
                            Height="30"
                            Padding="14,0"
                            Cursor="Hand"
                            IsEnabled="{Binding CanExportMap}"/>

                    <Button Grid.Column="3"
                            Content="{Binding ExportAllLabel}"
                            Command="{Binding ExportAllMapsCommand}"
                            Template="{StaticResource CtaBtn}"
                            Foreground="White"
                            FontSize="12"
                            Height="30"
                            Padding="14,0"
                            Cursor="Hand"
                            IsEnabled="{Binding CanExportAll}"/>
                </Grid>
            </Border>

            <TabControl Grid.Row="1">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background"
                                Value="#F3F3F3"/>
                    </Style>
                </TabControl.Resources>

                <!-- Tab: Preview -->
                <TabItem Header="Preview">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#111111">
                        <Grid>
                            <Image Source="{Binding MapImage}"
                                   Stretch="None"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <TextBlock Text="Rendering…"
                                       Foreground="White"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsRenderingMap, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab: Teleports -->
                <TabItem Header="Teleports">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Status bar -->
                        <Border Grid.Row="0"
                                Background="White"
                                Padding="16,8"
                                BorderBrush="#D1D1D1"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="{Binding TransferStatusText}"
                                           FontSize="11"
                                           Foreground="#767676"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Searching…"
                                           FontSize="11"
                                           Foreground="{StaticResource AppColorMain2Brush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSearchingTransfers, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>

                        <!-- Results -->
                        <ScrollViewer Grid.Row="1"
                                      Grid.RowSpan="2"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="MAP EVENTS"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="16,12,16,4"/>
                                <DataGrid ItemsSource="{Binding MapTransferResults}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Source Map"
                                                            Binding="{Binding MapDisplay}"
                                                            Width="160"/>
                                        <DataGridTextColumn Header="Event"
                                                            Binding="{Binding EventDisplay}"
                                                            Width="160"/>
                                        <DataGridTextColumn Header="Page"
                                                            Binding="{Binding PageDisplay}"
                                                            Width="70"/>
                                        <DataGridTextColumn Header="Detail"
                                                            Binding="{Binding Detail}"
                                                            Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="COMMON EVENTS"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="16,14,16,4"/>
                                <DataGrid ItemsSource="{Binding CommonTransferResults}"
                                          MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"
                                                            Binding="{Binding EventId, StringFormat=D3}"
                                                            Width="60"/>
                                        <DataGridTextColumn Header="Name"
                                                            Binding="{Binding EventName}"
                                                            Width="200"/>
                                        <DataGridTextColumn Header="Detail"
                                                            Binding="{Binding Detail}"
                                                            Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
