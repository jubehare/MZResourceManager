<UserControl x:Class="MZResourceManager.Views.ScriptBookExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                Padding="24,18"
                BorderBrush="#D1D1D1"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Script Book Export"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Export all map events and common events to a readable text file."
                           FontSize="12"
                           Foreground="#767676"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,24,24,24">
            <StackPanel MaxWidth="480"
                        HorizontalAlignment="Left">

                <Border Background="White"
                        BorderBrush="#D1D1D1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="OPTIONS"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#767676"
                                   Margin="0,0,0,14"/>

                        <CheckBox Content="Include Map Events"
                                  IsChecked="{Binding IncludeMaps}"
                                  FontSize="13"
                                  Foreground="#1A1A1A"
                                  Margin="0,0,0,10"/>

                        <CheckBox Content="Include Common Events"
                                  IsChecked="{Binding IncludeCommonEvents}"
                                  FontSize="13"
                                  Foreground="#1A1A1A"
                                  Margin="0,0,0,10"/>

                        <CheckBox Content="Include empty pages / events"
                                  IsChecked="{Binding IncludeEmptyPages}"
                                  FontSize="13"
                                  Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>

                <Button Content="{Binding ExportLabel}"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding CanExport}"
                        Template="{StaticResource CtaBtn}"
                        Foreground="White"
                        FontSize="13"
                        Height="40"
                        Cursor="Hand"
                        Margin="0,0,0,14"/>

                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{StaticResource AppColorMain2Brush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}"
                                             Value="">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}"
                                             Value="{x:Null}">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
