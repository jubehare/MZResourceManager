<UserControl x:Class="MZResourceManager.Views.TextSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Border Grid.Row="0"
                Padding="16,12"
                BorderBrush="{StaticResource AppColorBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="QueryBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             KeyDown="QueryBox_KeyDown"/>
                    <TextBlock Text="Enter keyword to search across all events and plugin data…"
                               IsHitTestVisible="False"
                               Foreground="#AAAAAA" FontSize="12"
                               Padding="10,7" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Grid.Column="2"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Template="{StaticResource CtaBtn}"
                        Foreground="White"
                        FontSize="12"
                        Width="72"
                        Height="32"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="1"
                Padding="16,6"
                BorderBrush="{StaticResource AppColorBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="{StaticResource AppColorTextMutedBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Searching…"
                           FontSize="11"
                           Foreground="{StaticResource AppColorMain2Brush}"
                           HorizontalAlignment="Right"
                           Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- Results -->
        <TabControl Grid.Row="2">

            <TabItem Header="Map Events">
                <DataGrid ItemsSource="{Binding MapResults}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Map"
                                            Binding="{Binding MapDisplay}"
                                            Width="160"/>
                        <DataGridTextColumn Header="Event"
                                            Binding="{Binding EventDisplay}"
                                            Width="160"/>
                        <DataGridTextColumn Header="Page"
                                            Binding="{Binding Page}"
                                            Width="50"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding CommandType}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Matched Text"
                                            Binding="{Binding MatchedText}"
                                            Width="350"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Common Events">
                <DataGrid ItemsSource="{Binding CommonResults}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Common Event"
                                            Binding="{Binding EventDisplay}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding CommandType}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Matched Text"
                                            Binding="{Binding MatchedText}"
                                            Width="350"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Battle Events">
                <DataGrid ItemsSource="{Binding TroopResults}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Troop"
                                            Binding="{Binding MapDisplay}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Page"
                                            Binding="{Binding EventDisplay}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding CommandType}"
                                            Width="130"/>
                        <DataGridTextColumn Header="Matched Text"
                                            Binding="{Binding MatchedText}"
                                            Width="350"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Plugin Settings">
                <DataGrid ItemsSource="{Binding PluginResults}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Plugin"
                                            Binding="{Binding PluginName}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Parameter"
                                            Binding="{Binding ParamKey}"
                                            Width="250"/>
                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding ParamValue}"
                                            Width="350"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
