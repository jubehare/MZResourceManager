<UserControl x:Class="MZResourceManager.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MZResourceManager.Views"
             xmlns:vm="clr-namespace:MZResourceManager.ViewModels">
        <Grid>
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar -->
                <Border Grid.Column="0"
                        Width="240"
                        Background="{StaticResource AppColorSideLightBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="20,24,20,20">
                                <StackPanel>

                                        <Grid Margin="0,0,0,6">
                                                <TextBlock Text="MZ Resource Manager"
                                                           FontSize="10"
                                                           Foreground="{StaticResource AppColorMain2Brush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Command="{Binding NavigateHomeCommand}"
                                                        HorizontalAlignment="Right"
                                                        Width="20"
                                                        Height="20"
                                                        Cursor="Hand"
                                                        ToolTip="About / Home">
                                                        <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Background="Transparent"
                                                                                BorderBrush="{StaticResource AppColorMain2Brush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="10">
                                                                                <TextBlock x:Name="Lbl"
                                                                                           Text="?"
                                                                                           FontSize="10"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="{StaticResource AppColorMain2Brush}"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver"
                                                                                         Value="True">
                                                                                        <Setter TargetName="Bd"
                                                                                                Property="Background"
                                                                                                Value="{StaticResource AppColorMain2Brush}"/>
                                                                                        <Setter TargetName="Lbl"
                                                                                                Property="Foreground"
                                                                                                Value="White"/>
                                                                                </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                        </Button.Template>
                                                </Button>
                                        </Grid>

                                        <TextBlock Text="{Binding GameTitle}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorSide2Brush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>

                                        <TextBlock Text="{Binding GameFolderDisplay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AppColorTextBodyBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>

                                        <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Open Another Folder…"
                                                        Command="{Binding OpenProjectCommand}"
                                                        Template="{StaticResource CtaBtn}"
                                                        Foreground="White"
                                                        FontSize="12"
                                                        Height="34"
                                                        Cursor="Hand"/>
                                                <Button Grid.Column="2"
                                                        Content="↺"
                                                        Command="{Binding ReloadProjectCommand}"
                                                        Template="{StaticResource CtaBtn}"
                                                        Foreground="White"
                                                        FontSize="16"
                                                        Width="34"
                                                        Height="34"
                                                        Cursor="Hand"
                                                        ToolTip="Reload project"/>
                                        </Grid>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,0,0,16"/>

                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Text Search"
                                                Content=""
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="TextSearch"
                                                Cursor="Hand"
                                                Margin="0,0,0,8"/>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,0,0,16"/>

                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Maps"
                                                Content="{Binding MapCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Maps"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Items"
                                                Content="{Binding ItemCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Items"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Switches"
                                                Content="{Binding SwitchCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Switches"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Variables"
                                                Content="{Binding VariableCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Variables"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Common Events"
                                                Content="{Binding CommonEventCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="CommonEvents"
                                                Cursor="Hand"/>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,16,0,12"/>

                                        <TextBlock Text="RESOURCES"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorMain2Brush}"
                                                   Margin="0,0,0,6"/>

                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Audio"
                                                Content="{Binding AudioCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResAudio"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Pictures"
                                                Content="{Binding PictureCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResPictures"
                                                Cursor="Hand"/>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Tilesets"
                                                Content="{Binding TilesetCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="TilesetAnalyze"
                                                Cursor="Hand"/>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,16,0,12"/>

                                        <TextBlock Text="TOOLS"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorMain2Brush}"
                                                   Margin="0,0,0,8"/>

                                        <Button Content="Unused Resource Scan"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="UnusedResources"
                                                Template="{StaticResource CtaBtn}"
                                                Foreground="White"
                                                FontSize="11"
                                                Height="30"
                                                Cursor="Hand"
                                                Margin="0,0,0,6"/>

                                        <Button Content="Script Book Export"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ScriptBookExport"
                                                Template="{StaticResource CtaBtn}"
                                                Foreground="White"
                                                FontSize="11"
                                                Height="30"
                                                Cursor="Hand"
                                                Margin="0,0,0,0"/>

                                </StackPanel>
                        </ScrollViewer>
                </Border>

                <!-- Right content area -->
                <Grid Grid.Column="1"
                      Background="{StaticResource AppColorMain1Brush}">

                        <views:HomeView
                                Visibility="{Binding ShowHome, Converter={StaticResource BoolToVis}}"/>
                        <views:MapListView Visibility="{Binding ShowMaps, Converter={StaticResource BoolToVis}}"/>
                        <views:ResourceSearchView
                                DataContext="{Binding ResourceSearch}"
                                Visibility="{Binding DataContext.ShowResourceSearch,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:NamedListView
                                DataContext="{Binding NamedList}"
                                Visibility="{Binding DataContext.ShowNamedList,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:UnusedResourcesView
                                DataContext="{Binding UnusedResources}"
                                Visibility="{Binding DataContext.ShowUnusedResources,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:TilesetAnalyzeView
                                DataContext="{Binding TilesetAnalyze}"
                                Visibility="{Binding DataContext.ShowTilesetAnalyze,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:ScriptBookExportView
                                DataContext="{Binding ScriptBookExport}"
                                Visibility="{Binding DataContext.ShowScriptBookExport,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:TextSearchView
                                DataContext="{Binding TextSearch}"
                                Visibility="{Binding DataContext.ShowTextSearch,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                </Grid>
        </Grid>
</UserControl>
