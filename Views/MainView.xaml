<UserControl x:Class="MZResourceManager.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MZResourceManager.Views"
             xmlns:vm="clr-namespace:MZResourceManager.ViewModels">
        <Grid>
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar -->
                <Border Grid.Column="0"
                        Width="240"
                        Background="{StaticResource AppColorSideLightBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="20,24,20,20">
                                <StackPanel>

                                        <TextBlock Text="{Binding GameTitle}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorSide2Brush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,4"/>

                                        <TextBlock Text="{Binding GameFolderDisplay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AppColorTextBodyBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14"/>

                                        <!-- Search Text -->
                                        <Button Command="{Binding NavigateCommand}"
                                                CommandParameter="TextSearch"
                                                Cursor="Hand"
                                                Margin="0,0,0,2">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="TextSearch">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="3"
                                                                        Padding="6,5">
                                                                        <Grid>
                                                                                <TextBlock Text="Search Text"
                                                                                           FontSize="12"
                                                                                           Foreground="{StaticResource AppColorSide2Brush}"
                                                                                           VerticalAlignment="Center"/>
                                                                                <TextBlock Text="&#xE721;"
                                                                                           FontFamily="Segoe MDL2 Assets"
                                                                                           FontSize="11"
                                                                                           Foreground="{StaticResource AppColorTextMutedBrush}"
                                                                                           HorizontalAlignment="Right"
                                                                                           VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AppColorSideLightHoverBrush}"/>
                                                                        </Trigger>
                                                                </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                </Button.Template>
                                        </Button>

                                        <!-- Plugin Command Search -->
                                        <Button Command="{Binding NavigateCommand}"
                                                CommandParameter="PluginCmdSearch"
                                                Cursor="Hand"
                                                Margin="0,0,0,4">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="PluginCmdSearch">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="3"
                                                                        Padding="6,5">
                                                                        <Grid>
                                                                                <TextBlock Text="Plugin Commands"
                                                                                           FontSize="12"
                                                                                           Foreground="{StaticResource AppColorSide2Brush}"
                                                                                           VerticalAlignment="Center"/>
                                                                                <TextBlock Text="&#xE8A9;"
                                                                                           FontFamily="Segoe MDL2 Assets"
                                                                                           FontSize="11"
                                                                                           Foreground="{StaticResource AppColorTextMutedBrush}"
                                                                                           HorizontalAlignment="Right"
                                                                                           VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AppColorSideLightHoverBrush}"/>
                                                                        </Trigger>
                                                                </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                </Button.Template>
                                        </Button>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,12,0,16"/>

                                        <TextBlock Text="DATABASE"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorMain2Brush}"
                                                   Margin="0,0,0,6"/>

                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Maps"
                                                Content="{Binding MapCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Maps"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="Maps">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Items"
                                                Content="{Binding ItemCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Items"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="Items">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Switches"
                                                Content="{Binding SwitchCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Switches"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="Switches">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Variables"
                                                Content="{Binding VariableCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="Variables"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="Variables">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Common Events"
                                                Content="{Binding CommonEventCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="CommonEvents"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="CommonEvents">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>

                                        <Separator Background="{StaticResource AppColorBorderBrush}"
                                                   Margin="0,12,0,16"/>

                                        <TextBlock Text="RESOURCES"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AppColorMain2Brush}"
                                                   Margin="0,0,0,6"/>

                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Audio"
                                                Content="{Binding AudioCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResAudio"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResAudio">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Sprites"
                                                Content="{Binding SpriteCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResSprites"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResSprites">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Animations"
                                                Content="{Binding AnimCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResAnimations"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResAnimations">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Backgrounds"
                                                Content="{Binding BgCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResBackgrounds"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResBackgrounds">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Pictures"
                                                Content="{Binding PictureCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResPictures"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResPictures">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="System / UI"
                                                Content="{Binding SystemUICount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="ResSystemUI"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="ResSystemUI">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                        <Button Template="{StaticResource NavBtn}"
                                                Tag="Tilesets"
                                                Content="{Binding TilesetCount}"
                                                Command="{Binding NavigateCommand}"
                                                CommandParameter="TilesetAnalyze"
                                                Cursor="Hand">
                                                <Button.Style>
                                                        <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveTabKey}" Value="TilesetAnalyze">
                                                                                <Setter Property="Background" Value="{StaticResource NavBtnSelectedBrush}"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>


                                </StackPanel>
                        </ScrollViewer>
                </Border>

                <!-- Right content area -->
                <Grid Grid.Column="1"
                      Background="{StaticResource AppColorMain1Brush}">

                        <views:HomeView
                                Visibility="{Binding ShowHome, Converter={StaticResource BoolToVis}}"/>
                        <views:MapListView Visibility="{Binding ShowMaps, Converter={StaticResource BoolToVis}}"/>
                        <views:ResourceSearchView
                                DataContext="{Binding ResourceSearch}"
                                Visibility="{Binding DataContext.ShowResourceSearch,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:NamedListView
                                DataContext="{Binding NamedList}"
                                Visibility="{Binding DataContext.ShowNamedList,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:TilesetAnalyzeView
                                DataContext="{Binding TilesetAnalyze}"
                                Visibility="{Binding DataContext.ShowTilesetAnalyze,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:TextSearchView
                                DataContext="{Binding TextSearch}"
                                Visibility="{Binding DataContext.ShowTextSearch,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                        <views:PluginCmdSearchView
                                DataContext="{Binding PluginCmdSearch}"
                                Visibility="{Binding DataContext.ShowPluginCmdSearch,
                                             RelativeSource={RelativeSource AncestorType=Grid},
                                             Converter={StaticResource BoolToVis}}"/>
                </Grid>
        </Grid>
</UserControl>
