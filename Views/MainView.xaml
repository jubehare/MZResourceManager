<UserControl x:Class="MZResourceManager.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid>
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar -->
                <Border Grid.Column="0"
                        Background="{StaticResource AppColorSide2Brush}"
                        Padding="20,24,20,20">
                        <StackPanel>

                                <TextBlock Text="MZ Resource Manager"
                                           FontSize="10"
                                           Foreground="{StaticResource AppColorMain2Brush}"
                                           Margin="0,0,0,6"/>

                                <TextBlock Text="{Binding GameTitle}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AppColorMain1Brush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"/>

                                <TextBlock Text="{Binding GameFolderDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource AppColorMain1Brush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <Button Content="Open Another Folder…"
                                        Command="{Binding OpenProjectCommand}"
                                        Template="{StaticResource CtaBtn}"
                                        Foreground="White"
                                        FontSize="12"
                                        Height="34"
                                        Cursor="Hand"
                                        Margin="0,0,0,20"/>

                                <Separator Background="{StaticResource AppColorSide1Brush}"
                                           Margin="0,0,0,16"/>

                                <Button Template="{StaticResource NavBtn}"
                                        Tag="Maps"
                                        Content="{Binding MapCount}"
                                        Cursor="Hand"/>
                                <Button Template="{StaticResource NavBtn}"
                                        Tag="Items"
                                        Content="{Binding ItemCount}"
                                        Cursor="Hand"/>
                                <Button Template="{StaticResource NavBtn}"
                                        Tag="Switches"
                                        Content="{Binding SwitchCount}"
                                        Cursor="Hand"/>
                                <Button Template="{StaticResource NavBtn}"
                                        Tag="Variables"
                                        Content="{Binding VariableCount}"
                                        Cursor="Hand"/>
                                <Button Template="{StaticResource NavBtn}"
                                        Tag="Common Events"
                                        Content="{Binding CommonEventCount}"
                                        Cursor="Hand"/>

                        </StackPanel>
                </Border>

                <!-- Right content area -->
                <Grid Grid.Column="1"
                      Background="{StaticResource AppColorMain1Brush}"/>
        </Grid>
</UserControl>
