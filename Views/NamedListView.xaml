<UserControl x:Class="MZResourceManager.Views.NamedListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#D1D1D1"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        Padding="14,12"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AppColorSide2Brush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AllEntries.Count, StringFormat=' ({0})'}"
                                   FontSize="11"
                                   Foreground="{StaticResource AppColorMain2Brush}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        Padding="8,8"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             FontSize="12"
                             BorderBrush="#D1D1D1"
                             BorderThickness="1"/>
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredEntries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="White"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"
                                    Value="12,7"/>
                            <Setter Property="BorderThickness"
                                    Value="0,0,0,1"/>
                            <Setter Property="BorderBrush"
                                    Value="#D1D1D1"/>
                            <Setter Property="Background"
                                    Value="White"/>
                            <Setter Property="Foreground"
                                    Value="#1A1A1A"/>
                            <Setter Property="FontSize"
                                    Value="12"/>
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Padding="{TemplateBinding Padding}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background"
                                                        Value="#0078D4"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver"
                                                               Value="True"/>
                                                    <Condition Property="IsSelected"
                                                               Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd"
                                                        Property="Background"
                                                        Value="#E5F1FB"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id, StringFormat=D4}"
                                           FontSize="10"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#767676"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#D1D1D1"
                    BorderThickness="0,0,0,1"
                    MinHeight="64">
                <Grid Margin="18,14">

                    <TextBlock Text="Select an entry to find usages"
                               Foreground="#999999"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ShowNoSelection, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowNoSelection}"
                                                       Value="False"/>
                                            <Condition Binding="{Binding ShowItemDetail}"
                                                       Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Background="{StaticResource AppColorMain2Brush}"
                                CornerRadius="4"
                                Padding="8,3"
                                Margin="0,0,10,0">
                            <TextBlock Text="{Binding SelectedEntry.Id, StringFormat=D4}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Text="{Binding SelectedEntry.Name}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Visibility="{Binding ShowItemDetail, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Margin="0,0,24,0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,4">
                                <Border Background="{StaticResource AppColorMain2Brush}"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedEntry.Id, StringFormat=D4}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="{Binding SelectedItemDetail.Name}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedItemDetail.Description}"
                                       FontSize="11"
                                       Foreground="#3C3C3C"
                                       TextWrapping="Wrap"
                                       MaxWidth="320"/>
                        </StackPanel>

                        <Grid Grid.Column="1"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0"
                                        Grid.Row="0"
                                        Margin="0,0,20,6">
                                <TextBlock Text="TYPE"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.TypeLabel}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="0,0,20,6">
                                <TextBlock Text="OCCASION"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.OccasionLabel}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Grid.Row="0"
                                        Margin="0,0,20,6">
                                <TextBlock Text="SCOPE"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.ScopeLabel}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Grid.Row="0"
                                        Margin="0,0,0,6">
                                <TextBlock Text="PRICE"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.Price}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0"
                                        Grid.Row="1"
                                        Margin="0,0,20,0">
                                <TextBlock Text="CONSUMABLE"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.ConsumableLabel}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Grid.Row="1"
                                        Margin="0,0,20,0">
                                <TextBlock Text="SUCCESS %"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.SuccessRate, StringFormat={}{0}%}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Grid.Row="1"
                                        Margin="0,0,20,0">
                                <TextBlock Text="REPEATS"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.Repeats}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Grid.Row="1">
                                <TextBlock Text="SPEED"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#767676"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedItemDetail.Speed}"
                                           FontSize="12"
                                           Foreground="#1A1A1A"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18,7">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="#767676"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Searching…"
                           FontSize="11"
                           Foreground="{StaticResource AppColorMain2Brush}"
                           HorizontalAlignment="Right"
                           Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <TabControl Grid.Row="2">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background"
                                Value="#F3F3F3"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Map Events">
                    <DataGrid ItemsSource="{Binding MapResults}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Map"
                                                Binding="{Binding MapDisplay}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Event"
                                                Binding="{Binding EventDisplay}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Page"
                                                Binding="{Binding PageDisplay}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Detail"
                                                Binding="{Binding Detail}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Common Events">
                    <DataGrid ItemsSource="{Binding CommonResults}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding EventId, StringFormat=D3}"
                                                Width="60"/>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding EventName}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Detail"
                                                Binding="{Binding Detail}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Plugin Parameters">
                    <DataGrid ItemsSource="{Binding PluginResults}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Plugin"
                                                Binding="{Binding PluginName}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Parameter"
                                                Binding="{Binding ParamKey}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Value"
                                                Binding="{Binding ParamValue}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
