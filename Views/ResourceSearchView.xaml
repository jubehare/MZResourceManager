<UserControl x:Class="MZResourceManager.Views.ResourceSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#D1D1D1"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        Padding="14,12"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding CategoryTitle}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppColorSide2Brush}"/>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        Padding="8,6"
                        BorderBrush="#D1D1D1"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"
                                 FontSize="12"
                                 BorderBrush="#D1D1D1"
                                 BorderThickness="1"
                                 Margin="0,0,0,6"/>

                        <ItemsControl ItemsSource="{Binding SubFolderOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding DataContext.SelectSubFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,4,4"
                                            Padding="8,3"
                                            FontSize="10"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background"
                                                        Value="#D1D1D1"/>
                                                <Setter Property="Foreground"
                                                        Value="#1A1A1A"/>
                                                <Setter Property="BorderThickness"
                                                        Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="10"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="Bd"
                                                                            Property="Background"
                                                                            Value="#0078D4"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredEntries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="White"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding SubFolder}"
                                           FontSize="10"
                                           Foreground="#767676">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SubFolder}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#D1D1D1"
                    BorderThickness="0,0,0,1"
                    MinHeight="110">
                <Grid Margin="18,14">

                    <TextBlock Text="Select a file to preview"
                               Foreground="#999999"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ShowNoSelection, Converter={StaticResource BoolToVis}}"/>

                    <Grid Visibility="{Binding ShowImagePreview, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding SelectedEntry.Name}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   Margin="0,0,0,8"/>

                        <Image Grid.Row="1"
                               Source="{Binding PreviewImageSource}"
                               MaxHeight="180"
                               Stretch="Uniform"
                               HorizontalAlignment="Left"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Grid>

                    <Grid Visibility="{Binding ShowAudioPreview, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedEntry.Name}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A1A"
                                       VerticalAlignment="Center"/>
                            <Border Background="{StaticResource AppColorMain2Brush}"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding AudioTypeLabel}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal">
                            <Button x:Name="PlayBtn"
                                    Padding="10,4"
                                    Content="▶  Play"
                                    Click="PlayButton_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="StopBtn"
                                    Padding="10,4"
                                    Content="■  Stop"
                                    Click="StopButton_Click"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18,7">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="#767676"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Searching..."
                           FontSize="11"
                           Foreground="{StaticResource AppColorMain2Brush}"
                           HorizontalAlignment="Right"
                           Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <TabControl Grid.Row="2">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background"
                                Value="#F3F3F3"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Map Events">
                    <DataGrid ItemsSource="{Binding MapResults}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Map"
                                                Binding="{Binding MapDisplay}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Event"
                                                Binding="{Binding EventDisplay}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Page"
                                                Binding="{Binding PageDisplay}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Detail"
                                                Binding="{Binding Detail}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Common Events">
                    <DataGrid ItemsSource="{Binding CommonResults}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding EventId, StringFormat=D3}"
                                                Width="60"/>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding EventName}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Detail"
                                                Binding="{Binding Detail}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
